---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Eugenio Pallestrini — Medico, Presidente del Teatro Stabile di Genova, Museo Biblioteca dell\'Attore',
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="it_IT" />

    <!-- Schema.org Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Eugenio Pallestrini",
      "jobTitle": "Primario ORL",
      "affiliation": [
        { "@type": "Organization", "name": "Teatro Stabile di Genova" },
        { "@type": "Organization", "name": "Museo Biblioteca dell'Attore" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Genova",
        "addressCountry": "IT"
      },
      "url": "https://www.eugeniopallestrini.it"
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const animations: Record<string, gsap.TweenVars> = {
        'fade-up': { y: 40, opacity: 0 },
        'fade-left': { x: 40, opacity: 0 },
        'fade-right': { x: -40, opacity: 0 },
      };

      document.querySelectorAll<HTMLElement>('[data-animate]').forEach((el) => {
        const type = el.dataset.animate || 'fade-up';
        const from = animations[type] || animations['fade-up'];

        gsap.from(el, {
          ...from,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            once: true,
          },
        });
      });
    </script>
  </body>
</html>
