---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Contatti — Eugenio Pallestrini"
  description="Contatti del Prof. Eugenio Pallestrini: telefono, email, social."
>

  <PageHero
    title="Contatti"
    subtitle="Per informazioni, collaborazioni o richieste."
    breadcrumb={[{ label: 'Contatti' }]}
  />

  <section class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-6">

      <div class="space-y-6">

        <div class="p-6 bg-white border border-border rounded-xl">
          <h3 class="text-lg mb-1">Telefono</h3>
          <p class="text-muted">
            <a href="tel:+39010312030" class="text-night hover:text-gold transition-colors">010 312030</a>
            <span class="text-border-dark mx-2">/</span>
            <a href="tel:+393389338436" class="text-night hover:text-gold transition-colors">338 9338436</a>
          </p>
        </div>

        <div class="p-6 bg-white border border-border rounded-xl">
          <h3 class="text-lg mb-1">Email</h3>
          <p class="text-muted">
            <a href="mailto:eugenio.pallestrini@gmail.com" class="text-night hover:text-gold transition-colors">
              eugenio.pallestrini@gmail.com
            </a>
          </p>
        </div>

        <div class="p-6 bg-white border border-border rounded-xl">
          <h3 class="text-lg mb-1">Social</h3>
          <div class="flex gap-4 mt-2">
            <a href="https://www.facebook.com/e.a.pallestrini" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
          </div>
        </div>

      </div>

      <div class="mt-12 rounded-2xl overflow-hidden shadow-lg" data-animate="fade-up">
        <img
          src="/images/genova.jpg"
          alt="Panorama di Genova"
          class="w-full h-48 object-cover"
          width="449"
          height="253"
          loading="lazy"
        />
        <div class="p-6 bg-ivory-dark text-center">
          <p class="font-serif text-lg text-night-deep">
            Genova, Italia
          </p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
