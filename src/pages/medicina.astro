---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Medicina & Ricerca — Eugenio Pallestrini"
  description="Carriera medica di Eugenio Pallestrini: Primario ORL all'Ospedale San Martino di Genova, libero docente, ricercatore."
>

  <PageHero
    title="Medicina & Ricerca"
    subtitle="Una carriera dedicata all'otorinolaringoiatria, dalla clinica alla ricerca scientifica."
  />

  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6">

      <!-- Foto -->
      <div class="mb-16 grid grid-cols-1 md:grid-cols-2 gap-8 items-center" data-animate="fade-up">
        <img
          src="/images/universita.jpg"
          alt="Eugenio Pallestrini all'Università di Genova"
          class="rounded-2xl shadow-lg w-full object-cover"
          width="600"
          height="400"
          loading="lazy"
        />
        <div>
          <p class="text-muted leading-relaxed">
            Una carriera lunga oltre quarant'anni, dalla clinica alla ricerca,
            passando per l'insegnamento universitario e i contributi alle linee guida nazionali.
          </p>
        </div>
      </div>

      <!-- Timeline -->
      <div class="space-y-12">

        <div class="relative pl-8 border-l-2 border-gold/30" data-animate="fade-up">
          <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-gold"></div>
          <p class="text-sm text-gold font-semibold uppercase tracking-wide mb-2">1982 &ndash; 2006</p>
          <h3>Primario O.R.L. &mdash; Ospedale San Martino</h3>
          <p class="mt-3 text-muted leading-relaxed">
            Per ventiquattro anni alla guida della Divisione di Otorinolaringoiatria del principale
            ospedale genovese. Attivit&agrave; clinica, chirurgica e di ricerca con focus su vestibologia,
            allergologia e antibioticoterapia in ambito O.R.L.
          </p>
        </div>

        <div class="relative pl-8 border-l-2 border-gold/30" data-animate="fade-up">
          <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-gold"></div>
          <p class="text-sm text-gold font-semibold uppercase tracking-wide mb-2">Docenza</p>
          <h3>Libero Docente in Clinica O.R.L.</h3>
          <p class="mt-3 text-muted leading-relaxed">
            Attivit&agrave; di insegnamento e formazione specialistica. Contributo alla formazione
            di generazioni di specialisti otorinolaringoiatri presso l'Universit&agrave; di Genova.
          </p>
        </div>

        <div class="relative pl-8 border-l-2 border-gold/30" data-animate="fade-up">
          <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-gold"></div>
          <p class="text-sm text-gold font-semibold uppercase tracking-wide mb-2">1993</p>
          <h3>DRTC &mdash; Dipartimento Regionale Testa Collo</h3>
          <p class="mt-3 text-muted leading-relaxed">
            Curatore del Fascicolo Dipartimentale del DRTC della Regione Liguria,
            struttura di coordinamento regionale per le patologie del distretto testa-collo.
          </p>
        </div>

        <div class="relative pl-8 border-l-2 border-gold/30" data-animate="fade-up">
          <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-gold"></div>
          <p class="text-sm text-gold font-semibold uppercase tracking-wide mb-2">2008</p>
          <h3>Linee Guida &mdash; Istituto Superiore di Sanit&agrave;</h3>
          <p class="mt-3 text-muted leading-relaxed">
            Contributo alle Linee Guida nazionali sull'appropriatezza e sicurezza degli interventi
            di tonsillectomia e/o adenoidectomia, pubblicate dall'Istituto Superiore di Sanit&agrave;.
          </p>
        </div>

        <div class="relative pl-8 border-l-2 border-gold/30" data-animate="fade-up">
          <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-gold"></div>
          <p class="text-sm text-gold font-semibold uppercase tracking-wide mb-2">Ricerca</p>
          <h3>Aree di Specializzazione</h3>
          <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-4">
            {['Vestibologia', 'Allergologia O.R.L.', 'Antibioticoterapia', 'Chirurgia O.R.L.', 'AIDS e O.R.L.', 'Storia della O.R.L.'].map(area => (
              <div class="flex items-center gap-3 text-muted">
                <span class="w-2 h-2 rounded-full bg-gold/60 shrink-0"></span>
                {area}
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Link Scholar -->
      <div class="mt-16 p-8 bg-white border border-border rounded-2xl text-center">
        <h3 class="mb-3">Profilo Accademico</h3>
        <p class="text-muted mb-6">
          Consulta le pubblicazioni scientifiche su Google Scholar e ResearchGate.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="https://scholar.google.com/citations?user=PLACEHOLDER" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-night-deep text-ivory rounded-lg hover:bg-gold transition-colors text-sm font-medium">
            Google Scholar
          </a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
