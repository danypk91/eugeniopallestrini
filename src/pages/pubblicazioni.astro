---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const libri = [
  {
    titolo: 'Antibioticoterapia in O.R.L.',
    autori: 'Pallestrini E., Marcucci L., Schito G.',
    editore: 'Accademia Nazionale di Medicina — Forum editore',
    anno: 2000,
  },
  {
    titolo: 'D.R.G. R.O.D. in O.R.L.',
    autori: 'A cura di Pallestrini E.',
    editore: 'Pacini editore — Quaderni monografici di aggiornamento A.O.O.I.',
    anno: 1998,
  },
  {
    titolo: 'Allergie In Otorinolaringoiatria: Tecniche Diagnostiche e Terapeutiche',
    autori: 'Pallestrini E., Passali D.',
    editore: 'Pacini editore / Forum Service — Scuola Superiore Scienze Biomediche',
    anno: 1992,
  },
  {
    titolo: 'Le Manifestazioni dell\'A.I.D.S. in Otorinolaringoiatria',
    autori: 'A cura di Mencacci P., Pallestrini E., Sperati G.',
    editore: 'Pacini editore — Convegno Aggiornamento AOOI, Lucca',
    anno: 1992,
  },
  {
    titolo: 'Storia della O.R.L. a Genova e Torino',
    autori: 'Pallestrini E., Sperati G.',
    editore: 'In Dino Felisati "I Cento Anni della Otorinolaringoiatria Italiana" — Giunti editore',
    anno: 1992,
  },
  {
    titolo: 'Otorinolaringoiatria per infermieri professionali',
    autori: 'Pallestrini E., Dato M.T.',
    editore: 'Sorbona editore',
    anno: 1991,
  },
  {
    titolo: 'Linee Guida Tonsillectomia — Istituto Superiore di Sanità',
    autori: 'Contributo di Pallestrini E.',
    editore: 'Istituto Superiore di Sanità — Documento 15',
    anno: 2008,
  },
  {
    titolo: 'Fascicolo Dipartimentale DRTC Genova',
    autori: 'A cura di Pallestrini E., Tel A.',
    editore: 'DRTC Dipartimento Regionale Testa Collo — Regione Liguria',
    anno: 1993,
  },
];
---

<BaseLayout
  title="Pubblicazioni — Eugenio Pallestrini"
  description="Libri e pubblicazioni scientifiche di Eugenio Pallestrini: antibioticoterapia, vestibologia, allergologia in O.R.L."
>

  <PageHero
    title="Pubblicazioni"
    subtitle="Libri, monografie e contributi scientifici nell'ambito dell'otorinolaringoiatria."
    breadcrumb={[{ label: 'Pubblicazioni' }]}
  />

  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6">

      <div class="space-y-6">
        {libri.map((libro) => (
          <article class="p-6 md:p-8 bg-white border border-border rounded-xl hover:border-gold/30 transition-colors" data-animate="fade-up">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h3 class="text-lg md:text-xl">{libro.titolo}</h3>
                <p class="text-muted mt-2">{libro.autori}</p>
                <p class="text-sm text-muted-light mt-1">{libro.editore}</p>
              </div>
              <span class="shrink-0 text-2xl font-serif font-semibold text-gold/60">{libro.anno}</span>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-muted">
          Per l'elenco completo delle pubblicazioni scientifiche, consulta il profilo
          <a href="https://scholar.google.com/" target="_blank" rel="noopener" class="text-gold hover:underline">Google Scholar</a>.
        </p>
      </div>

    </div>
  </section>

</BaseLayout>
