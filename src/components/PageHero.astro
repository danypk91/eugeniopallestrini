---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-night-deep py-10 md:py-16">
  <div class="max-w-5xl mx-auto px-6">
    <h1 class="!text-ivory">{title}</h1>
    {subtitle && (
      <p class="mt-3 text-lg text-ivory/70 max-w-2xl">{subtitle}</p>
    )}
  </div>
</section>